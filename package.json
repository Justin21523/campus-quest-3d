{
  "name": "campus-quest-3d",
  "version": "0.1.0",
  "private": true,
  "description": "A full-stack 3D campus adventure game with React, Three.js, Node.js, MongoDB, and Python AI services.",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/shared-types",
    "packages/game-data"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:ai\"",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:ai": "cd apps/ai-service && . .venv/bin/activate && uvicorn app.main:app --reload --host 0.0.0.0 --port 8001",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace apps/web",
    "build:api": "npm run build --workspace apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "check:health": "node scripts/check-health.mjs",
    "demo:dev": "python3 -m http.server 4173 --directory demo-app",
    "demo:build": "node -e \"require('fs').accessSync('demo-app/index.html')\"",
    "demo:preview": "python3 -m http.server 4173 --directory demo-app"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@emnapi/wasi-threads": "1.2.1",
    "@napi-rs/wasm-runtime": "1.1.4",
    "@tybys/wasm-util": "0.10.2"
  }
}
